# =========================================================================
# LANZARUS API KEYS & SECRETS CONFIGURATION TEMPLATE
# Copy these values to your active '.env' file and replace with your real keys
# =========================================================================

# Google Gemini API Key for dynamic financial reports
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Production Gateway URL for the Lanzarus Android Application API Endpoint
# Change to http://10.0.2.2:3000/ to test against your local Node.js server.js in Emulator
BACKEND_API_URL=https://api.lanzarus.finance/v1/

# The exclusive signature key to sign outgoing webhook payouts from the Android app
LANZARUS_WEBHOOK_SECRET=YOUR_PRODUCTION_WEBHOOK_SECRET_HERE
LIVE_SECRET_KEY=YOUR_PRODUCTION_WEBHOOK_SECRET_HERE

# Root Administrator Firebase or system UID used to authenticate exclusive backend requests
LANZARUS_ADMIN_UID=YOUR_MASTER_ADMIN_UID_HERE
FIREBASE_ADMIN_UID=YOUR_MASTER_ADMIN_UID_HERE

# Plaid sandbox/live credentials for secure bank integration card flow
PLAID_CLIENT_ID=YOUR_PLAID_CLIENT_ID_HERE
PLAID_SECRET=YOUR_PLAID_SECRET_HERE
